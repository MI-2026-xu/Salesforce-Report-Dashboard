# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.

# ─── Salesforce Connected App ─────────────────────────────────────────────────
SF_CONSUMER_KEY=your_salesforce_consumer_key
SF_CONSUMER_SECRET=your_salesforce_consumer_secret
SF_DOMAIN=login

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Local dev: use individual vars below.
# Railway: set DATABASE_URL and leave the others blank (Railway provides it).
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sf_dashboard
DB_USER=postgres
DB_PASSWORD=your_db_password

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Railway / Upstash: paste the full URL here
REDIS_URL=redis://localhost:6379

# ─── JWT + Encryption ─────────────────────────────────────────────────────────
# Generate JWT_SECRET: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_64_char_hex_secret
JWT_EXPIRE_MINUTES=10080

# Generate ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_with_fernet_key

# ─── App URLs ─────────────────────────────────────────────────────────────────
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ALLOWED_ORIGINS: comma-separated list of allowed frontend origins.
# Production example: https://your-app.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ─── Sentry (optional) ────────────────────────────────────────────────────────
# Leave blank to disable. Get DSN from sentry.io.
SENTRY_DSN=
